      "visualization": { "arrow": "→", "color": "red", "icon": "emergency" }
    },
    "spell_execute": {
      "category": "governance",
      "direction": "directed",
      "from_role": "gov_chief (winning spell)",
      "to_role": "spell_instance + (target system contracts via pause_proxy)",
