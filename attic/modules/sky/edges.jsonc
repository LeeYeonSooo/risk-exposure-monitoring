      "activity_label": "dormant",
      "visualization": { "arrow": "→", "color": "red", "width": "bold", "icon": "shutdown" }
    },
    "d3m_emergency_cycle": {
      "category": "emergency",
      "direction": "directed",
      "from_role": "governance (cage) OR anyone after tau (cull) OR keeper (exit)",
      "to_role": "d3m_module",
      "source_event": "D3MHub.Emergency (Cage/Cull/Uncull/Exit 통합)",
      "description": "D3M pool 단계적 정리 (cage → tau wait → cull → exit). uncull은 End 시만",
      "visualization": { "arrow": "→", "color": "red", "style": "dashed" }
    },
    "urn_permission_grant": {
      "category": "governance",
      "direction": "directed",
      "from_role": "user_eoa (owner)",
      "to_role": "user_eoa (delegated usr)",
      "source_events": ["LockstakeEngine.Hope", "LockstakeEngine.Nope", "CDPManager.view_only (cdpAllow/urnAllow)"],
      "description": "★ user → user 권한 위임 — 위임받은 자가 urn 조작 가능. 신뢰 의존성",
      "visualization": { "arrow": "→", "color": "purple", "icon": "delegate" },
      "metadata": { "scope": "lockstake_urn at index OR cdp_vault_urn", "type4_handling": "CDPManager.cdpAllow/urnAllow은 이벤트 X — view polling" }
    },


    // ===== Category 14: external_operator (단방향 1) =====
    "external_operator_delegation": {
      "category": "external_operator",
      "direction": "directed",
      "from_role": "external_protocol_admin (Spark SubProxy)",
      "to_role": "d3m_module (D3MOperatorPlan)",
      "source_event": "D3MOperatorPlan.view_only (setTargetAssets)",
      "description": "★ Type 4 view-only — Spark가 D3M target 직접 결정 (Sky가 Spark에 신뢰 위임)",
      "visualization": { "arrow": "→", "color": "gray", "style": "dotted", "icon": "delegate" }
    },


    // ===== Category 15: oracle (단방향 2) =====
    "price_dependency": {
      "category": "oracle",
      "direction": "directed",
      "from_role": "ilk OR external_token OR psm",
      "to_role": "osm_wrapper OR price_feed OR custom_oracle",
      "source_events": ["static (constructor) + Spot.LogNote (file pip)"],
      "description": "자산의 가격 source 의존. multi-hop 가능 (ilk → osm → chainlink)",
      "visualization": { "arrow": "→", "color": "gray", "style": "dotted", "width": "thin" },
      "metadata": { "multi_hop": "osm → chainlink 같은 chain도 같은 edge_type으로 표현" }
    },


    // ===== Category 16: trust (단방향 1, 통합) =====
    "trust_dependency": {
      "category": "trust",
      "direction": "directed",
      "from_role": "external_token OR rwa_vault",
      "to_role": "offchain_issuer",
      "source_event": "static (issuer-token mapping)",
      "description": "★ off-chain trust. blacklist/pause/custody 권한 의존",
      "visualization": { "arrow": "→", "color": "gray", "style": "dotted", "icon": "trust" },
      "metadata": { "trust_type": "issuer (Circle USDC, BitGo WBTC) OR rwa_operator (BlockTower, Coinbase)" }
    }
  },


  // ===== 카테고리 시각화 요약 =====
  "_categories_summary": {
    "value_flow_swap": { "edges": ["psm_swap"], "color": "blue", "arrow": "↔" },
    "value_flow_yield": { "edges": ["savings_flow"], "color": "green", "arrow": "↔" },
    "vault_op": { "edges": ["vault_collateral_flow", "vault_debt_flow", "vault_open", "vault_transfer_ownership"], "color": "yellow", "arrow": "↔/→" },
    "conversion": { "edges": ["convert_token_bidir", "convert_token_oneway"], "color": "purple", "arrow": "↔/→" },
    "external_capital": { "edges": ["d3m_capital_flow", "allocator_capital_flow"], "color": "gray dashed", "arrow": "↔" },
    "cross_chain": { "edges": ["bridge_flow"], "color": "cyan dotted", "arrow": "↔" },
    "system_param": { "edges": ["ilk_parameter_change", "ilk_dynamic_line_adjust", "system_rate_accrue", "psm_keeper_action"], "color": "gray dotted", "arrow": "→" },
    "yield": { "edges": ["savings_yield_drip"], "color": "green dotted", "arrow": "→" },
    "risk_liquidation": { "edges": ["liquidation_kick", "liquidation_take", "bad_debt_absorb", "bad_debt_mint"], "color": "red bold", "arrow": "→" },
    "surplus_distribution": { "edges": ["surplus_to_burn", "burn_swap_external", "farm_reward_distribute"], "color": "yellow/orange", "arrow": "→" },
    "flash": { "edges": ["flash_callback"], "color": "purple dotted", "arrow": "→ cycle" },
    "governance": { "edges": ["gov_lock_sky", "vote_delegation", "farm_selection", "emergency_join", "spell_execute", "urn_permission_grant"], "color": "purple", "arrow": "→" },
    "emergency": { "edges": ["mom_breaker_trigger", "end_global_settlement_action", "d3m_emergency_cycle"], "color": "red", "arrow": "→" },
    "external_operator": { "edges": ["external_operator_delegation"], "color": "gray dotted", "arrow": "→" },
    "oracle": { "edges": ["price_dependency"], "color": "gray dotted thin", "arrow": "→" },
    "trust": { "edges": ["trust_dependency"], "color": "gray dotted", "arrow": "→" }
  }
}
