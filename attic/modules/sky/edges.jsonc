    },
    "end_global_settlement_action": {
      "category": "emergency",
      "direction": "directed",
      "from_role": "emergency_module (ESM.Fire) OR governance",
      "to_role": "end_module + (all_modules via cage cascade)",
      "source_events": ["ESM.Fire", "End.GlobalSettlement (cage/skim/snip/pack/cash 통합)"],
