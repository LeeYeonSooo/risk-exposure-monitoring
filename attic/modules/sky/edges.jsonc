      "visualization": { "arrow": "→", "color": "purple", "icon": "spell" },
      "metadata": { "creates_dynamic_node": "spell_instance (per Plot)" }
    },


    // ===== Category 13: emergency (단방향 4) =====
    "mom_breaker_trigger": {
      "category": "emergency",
      "direction": "directed",
      "from_role": "(anyone for tripBreaker OR governance) → breaker_mom",
      "to_role": "(target module — clipper OR osm_wrapper)",
      "source_events": ["ClipperMom.SetBreaker", "OSM_MOM.Stop"],
      "description": "permissionless 자동 trip (ClipperMom) OR governance 정지 (OSM_MOM 등)",
