// Sky/Maker 의존성 매핑 — events.jsonc v1.0
// 13 시나리오 학습 + CRITERIA v1.0 + plan v7.3 기반
//
// 역할: indexer가 이벤트 X 발견 → event_id로 lookup → produces_edges 자동 매핑
// 형식: Aave 양식 차용 (event_id = Contract.EventName, produces_edges 명시)
//
// 6 type 분류:
//   Type 1: Standard event (event_name + keccak256 topic0)
//   Type 2: LibNote anonymous (function_selector + bytes4 sig)
//   Type 3: Hybrid (standard + LogNote)
//   Type 4: View-only (이벤트 없음, view function polling)
//   Type 5: External event ref (외부 노드 emitted_events에서 참조)
//   Type 6: Callback hook (parent event + atomic_with)
//
// produces_edges에서 direction:
//   - "forward" / "reverse" — 양방향 엣지의 방향
//   - "directed" — 단방향 엣지
{
  "_metadata": {
    "version": "1.0",
    "date": "2026-05-28",
    "total_events": 53,
    "compatible_with": ["nodes.jsonc v1.0", "edges.jsonc v1.0"]
  },

  "events": [

    // ===== Type 1: Standard event (~32) =====

    // --- PSM (5) ---
    {
      "event_id": "LitePSM.SellGem",
      "type": 1,
      "filter_mode": "event_name",
      "source_contract_role": "psm",
      "signature": "SellGem(address indexed owner, uint256 value, uint256 fee)",
      "topic0": "<compute:keccak256(SellGem(address,uint256,uint256))>",
      "triggered_by": "user calls LitePSM.sellGem()",
      "description": "USDC → USDS swap (양방향 엣지 forward direction)",
      "produces_edges": [
        {
          "edge_type": "psm_swap",
          "direction": "forward",
          "from": "user_eoa",
          "to": "psm + psm_pocket",
          "asset_in": "tok_usdc",
          "asset_out": "tok_usds",
          "amount_in": "value (USDC gem precision)",
          "amount_out": "value × 10^12 - fee"
        }
      ],
      "related_side_events": ["USDC.Transfer(user→pocket)", "USDS.Transfer(psm→user)"]
    },
    {
      "event_id": "LitePSM.BuyGem",
      "type": 1,
      "filter_mode": "event_name",
      "source_contract_role": "psm",
      "signature": "BuyGem(address indexed owner, uint256 value, uint256 fee)",
      "topic0": "<compute>",
      "triggered_by": "user calls LitePSM.buyGem()",
      "description": "USDS → USDC swap (양방향 엣지 reverse direction)",
      "produces_edges": [
        {
          "edge_type": "psm_swap",
          "direction": "reverse",
          "from": "psm + psm_pocket",
          "to": "user_eoa",
          "asset_in": "tok_usds",
          "asset_out": "tok_usdc",
          "amount_in": "value × 10^12 + fee",
          "amount_out": "value (USDC gem precision)"
        }
      ]
    },
    {
