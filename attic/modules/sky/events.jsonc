      "signature": "LogMedianPrice(uint256 val, uint256 age)",
      "topic0": "<compute>",
      "triggered_by": "feeders poke median",
      "description": "Sky Median 가격 업데이트 — OSM의 upstream"
    },


    // ===== Type 4: View-only (이벤트 없음, polling) (4) =====

    {
      "event_id": "CDPManager.view_only",
      "type": 4,
      "filter_mode": "view_polling",
      "source_contract_role": "vault_engine",
      "view_functions": ["owns(uint256 cdp)", "cdpCan(address owner, uint256 cdp, address usr)", "urnCan(address urn, address usr)"],
      "poll_interval": "every_block",
      "triggered_by": "CDPManager.give() OR cdpAllow() OR urnAllow() (이벤트 없음)",
      "description": "★ Type 4 — vault 소유권 이전, urn 권한 위임 추적 (이벤트 X). view diff로 감지",
      "produces_edges": [
        { "edge_type": "vault_transfer_ownership", "direction": "directed", "when": "owns(cdp) changed", "from": "previous_owner", "to": "new_owner" },
        { "edge_type": "urn_permission_grant", "direction": "directed", "when": "cdpCan or urnCan changed", "from": "owner", "to": "delegated_usr" }
      ]
    },
    {
      "event_id": "D3MOperatorPlan.view_only",
      "type": 4,
      "filter_mode": "view_polling",
      "source_contract_role": "d3m_module",
      "view_function": "targetAssets()",
      "poll_interval": "every_block",
      "triggered_by": "external_protocol_admin (Spark SubProxy) calls setTargetAssets() (이벤트 없음)",
      "description": "★ Type 4 — Spark가 D3M에 원하는 USDS 양 변경. 다음 D3MHub.exec에서 Wind/Unwind 발생",
      "produces_edges": [
        { "edge_type": "external_operator_delegation", "direction": "directed", "from": "external_protocol_admin (Spark SubProxy)", "to": "d3m_module", "action": "set_target_assets" }
      ]
    },
    {
      "event_id": "VoteDelegateFactory.view_only",
      "type": 4,
      "filter_mode": "view_polling",
      "source_contract_role": "vote_delegate_factory",
      "view_function": "created(address voteDelegate)",
      "poll_interval": "on_demand",
      "description": "vote_delegate_instance 유효성 검증 (LockstakeEngine.selectVoteDelegate 시)",
      "produces_edges": []
    },
    {
      "event_id": "Pot.view_only",
      "type": 4,
      "filter_mode": "view_polling",
      "source_contract_role": "savings_module (dormant)",
      "view_functions": ["chi()", "pie(address)", "Pie()"],
      "poll_interval": "every_hour",
      "triggered_by": "Pot.drip/join/exit (이벤트 없음 — LibNote 제거됨)",
      "description": "★ Type 4 — Pot은 dormant. chi/pie view로 활동 추론",
      "produces_edges": [
        { "edge_type": "savings_flow", "direction": "varies", "when": "pie[user] changed" },
        { "edge_type": "savings_yield_drip", "direction": "directed", "when": "chi changed" }
      ]
    },


    // ===== Type 5: External event ref (5) =====

    {
      "event_id": "Spark.Borrow",
      "type": 5,
      "external_protocol": "spark",
      "source_contract_role": "external_protocol_pool",
      "emitting_contracts": ["ext_spark_lending_pool"],
      "description": "Spark 사용자가 USDS/DAI 빌림 — D3M 자본이 사용됨 (Sky 입장)",
      "produces_edges": [],
      "note": "Sky가 직접 emit 안 함. 외부 노드 emitted_events에 ref."
    },
    {
      "event_id": "Aave.Supply",
      "type": 5,
      "external_protocol": "aave_v3",
      "source_contract_role": "external_protocol_pool",
      "emitting_contracts": ["ext_aave_v3_lido_usds_pool"],
      "description": "Aave V3 사용자/Sky D3M이 자산 공급"
    },
    {
      "event_id": "Morpho.Withdraw",
      "type": 5,
      "external_protocol": "morpho",
      "source_contract_role": "external_protocol_pool",
      "emitting_contracts": ["ext_morpho_metamorpho"],
      "description": "Morpho MetaMorpho vault 활동"
    },
    {
      "event_id": "UniswapV2.Swap",
      "type": 5,
      "external_protocol": "uniswap_v2",
      "source_contract_role": "external_protocol_pool",
      "emitting_contracts": ["ext_uniswap_v2_usds_sky_pair"],
      "description": "USDS-SKY swap (Smart Burn 실행 + 일반 거래)"
    },
    {
      "event_id": "Chainlink.AnswerUpdated",
      "type": 5,
      "external_protocol": "chainlink",
      "source_contract_role": "price_feed",
      "description": "Chainlink Aggregator 가격 업데이트 — Sky OSM의 upstream"
    },


    // ===== Type 6: Callback hook (5) =====

    {
      "event_id": "LockstakeClipper.Take.with_cut",
      "type": 6,
      "parent_event": "Clipper.Take",
      "callback_target": "savings_module (stusds via cuttee)",
      "source_contract_role": "clipper (lockstake_clipper)",
      "triggered_by": "anyone calls LockstakeClipper.take() (sale.lot==0 && due>owe)",
      "description": "★ 가장 중요한 Callback — bad debt 자동 흡수",
      "produces_edges": [
        { "edge_type": "bad_debt_absorb", "direction": "directed", "from": "clipper (lockstake_clipper)", "to": "savings_module (stusds)", "amount": "due - owe" }
      ],
      "atomic_with": ["Clipper.Take (LockstakeClipper instance)", "stUSDS.Cut"]
    },
    {
      "event_id": "DssFlash.onFlashLoan",
      "type": 6,
      "parent_event": "DssFlash.FlashLoan",
      "callback_target": "receiver (user provided)",
      "source_contract_role": "(receiver, external)",
      "triggered_by": "DssFlash.flashLoan → receiver.onFlashLoan",
      "description": "flash loan callback — receiver가 임의 행위 가능 (차익거래, refinance 등)",
      "produces_edges": [],
      "note": "callback 내부 활동은 flash_callback edge metadata로 흡수"
    },
    {
      "event_id": "Clipper.clipperCall",
      "type": 6,
      "parent_event": "Clipper.Take",
      "callback_target": "buyer (user provided)",
      "source_contract_role": "(buyer, external)",
      "triggered_by": "Clipper.take with data param → buyer.clipperCall",
      "description": "flash buy 패턴 — 담보 받고 콜백에서 매도 후 USDS 지불 (자본 0)",
      "produces_edges": []
    },
    {
      "event_id": "LockstakeEngine.OnKick",
      "type": 6,
      "parent_event": "LockstakeClipper.Kick",
      "callback_target": "vault_engine (lockstake)",
      "source_contract_role": "vault_engine",
      "triggered_by": "LockstakeClipper.kick → engine.onKick",
      "description": "청산 시작 시 SKY를 vote_delegate/farm에서 unstake + LSSKY burn + urnAuctions++",
      "produces_edges": [],
      "atomic_with": ["LockstakeClipper.Kick"]
    },
    {
      "event_id": "LockstakeEngine.OnRemove",
      "type": 6,
      "parent_event": "LockstakeClipper.Take (sale.lot==0 OR sale.tab==0)",
      "callback_target": "vault_engine (lockstake)",
      "source_contract_role": "vault_engine",
      "triggered_by": "LockstakeClipper.take 종료 시 engine.onRemove",
      "description": "남은 SKY 환불 (fee burn 후 urn으로 LSSKY 재발행)",
      "produces_edges": []
    }
  ]
}
