      "produces_edges": [
        { "edge_type": "liquidation_kick", "direction": "directed", "from": "liquidation_router (Dog)", "to": "clipper (per ilk)", "auction_id": "id" }
      ],
      "callback_hook": "LockstakeClipper: engine.onKick + cuttee.drip"
    },
