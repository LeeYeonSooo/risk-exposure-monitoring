      "produces_edges": [
        { "edge_type": "savings_flow", "direction": "forward", "from": "user_eoa", "to": "savings_module", "asset_in": "tok_usds", "asset_out": "tok_susds OR tok_stusds (per emitting contract)", "amount_in": "assets", "amount_out": "shares" }
      ]
    },
